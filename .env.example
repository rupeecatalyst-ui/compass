ENTERPRISE_PERSISTENCE_MODE=memory
# Optional explicit tier: local | pilot | production (Vercel sets pilot/production automatically)
# CATALYST_DEPLOYMENT_TIER=local
# Demo business seeds run ONLY when NODE_ENV=development, tier=local, mode=memory.
# CATALYST_DEMO_SEEDS_ENABLED is baked at build time — always false on Vercel.

# Frontend (Next.js / Vercel)
NEXT_PUBLIC_APP_NAME=COMPASS
# Set to the public site URL (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Leave empty on Vercel (same-origin App Router /api).
# Local dual-server (Express): http://localhost:4000
NEXT_PUBLIC_API_URL=

# Auth / API (required on Vercel for App Router auth handlers that use server JWT)
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Express backend only (not used by Vercel Next deploy)
PORT=4000
NODE_ENV=production
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# -----------------------------------------------------------------------------
# PostgreSQL (Prisma) — paste from Supabase → Catalyst One Platform → Database
# Prefer secrets in .env.local (not committed).
# -----------------------------------------------------------------------------
DATABASE_URL=
DIRECT_URL=

# -----------------------------------------------------------------------------
# Supabase API — Catalyst One Platform (unpjfzvlokovobxgvazo)
# JWT auth is Prisma-backed; these are for Storage / optional integrations.
# -----------------------------------------------------------------------------
SUPABASE_PROJECT_ID=unpjfzvlokovobxgvazo
SUPABASE_URL=https://unpjfzvlokovobxgvazo.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://unpjfzvlokovobxgvazo.supabase.co
SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Legacy Vite aliases (same values if residual client paths need them)
# VITE_SUPABASE_URL=https://unpjfzvlokovobxgvazo.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_PROJECT_ID=unpjfzvlokovobxgvazo
