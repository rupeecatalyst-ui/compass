# Frontend — leave NEXT_PUBLIC_API_URL empty to proxy via Next.js (/api → backend)
NEXT_PUBLIC_APP_NAME=COMPASS
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=

# Backend
PORT=4000
NODE_ENV=development
DATABASE_URL=
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
